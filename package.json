{
  "name": "agentic-contacts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "API-only contacts service (Agentic Contacts) — Hono on Cloudflare Workers + D1, plus CLI",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "migrate": "wrangler d1 migrations apply agentic-contacts --remote",
    "migrate:local": "wrangler d1 migrations apply agentic-contacts --local",
    "cli": "tsx cli/contacts.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.42.0"
  }
}
