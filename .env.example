# Copy to .env and adjust. Data lives in a SEPARATE private repo so this code
# can be open-sourced without shipping anyone's contacts.
#   git clone <your-private-data-repo> ../p_98_contacts_data
CONTACTS_DATA_FILE=../p_98_contacts_data/contacts.json
COMPANIES_DATA_FILE=../p_98_contacts_data/companies.json
INTERACTIONS_DATA_FILE=../p_98_contacts_data/interactions.json
# Auto commit+push the data repo after each edit (debounced). 1 = on, 0 = off.
DATA_GIT_SYNC=0
DATA_GIT_SYNC_DEBOUNCE_MS=10000
